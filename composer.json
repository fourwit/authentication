{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "fourwit/authentication",
    "description": "Fourwit Authentication module package.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "fourwit/identity": "*",
        "nwidart/laravel-modules": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Authentication\\": "app/",
            "Modules\\Authentication\\Database\\Factories\\": "database/factories/",
            "Modules\\Authentication\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Authentication\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Authentication\\Providers\\AuthenticationServiceProvider"
            ],
            "aliases": {
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
